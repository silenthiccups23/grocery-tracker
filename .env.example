# Kroger API credentials (free at https://developer.kroger.com)
KROGER_CLIENT_ID=your_kroger_client_id_here
KROGER_CLIENT_SECRET=your_kroger_client_secret_here

# Turso cloud database (free at https://turso.tech)
# The app works with both local SQLite and Turso. If these are set, it uses Turso.
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Zip code for the price fetcher script (default: 92154)
FETCH_ZIP_CODE=92154

# Costco API via RapidAPI (optional, free at https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-costco-data)
RAPIDAPI_KEY=
